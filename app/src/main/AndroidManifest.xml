<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.example.univents">

    <!-- INTERNET -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Univents"
        android:usesCleartextTraffic="true"
        tools:ignore="GoogleAppIndexingWarning">

        <!-- ===================== -->
        <!-- LOGIN (LAUNCHER) -->
        <!-- ===================== -->
        <activity
            android:name=".UserLoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- REGISTER -->
        <activity
            android:name=".UserRegisterActivity"
            android:exported="false" />

        <!-- FORGOT PASSWORD -->
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- MAIN USER APP -->
        <!-- ===================== -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- 🔥 SEARCH ACTIVITY (INI YANG BIKIN CRASH SEBELUMNYA) -->
        <activity
            android:name=".SearchActivity"
            android:exported="false" />

        <!-- EVENT DETAIL -->
        <activity
            android:name=".EventDetailActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- PROFILE -->
        <!-- ===================== -->
        <activity
            android:name=".EditProfileActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- ADMIN -->
        <!-- ===================== -->
        <activity
            android:name=".AdminHomeActivity"
            android:exported="false" />

        <activity
            android:name=".AdminAddEventActivity"
            android:exported="false" />

        <activity
            android:name=".AdminManageEventActivity"
            android:exported="false" />

        <activity
            android:name=".AdminCloseEventActivity"
            android:exported="false" />

        <activity
            android:name=".AdminEditEventActivity"
            android:exported="false" />

        <activity
            android:name=".AdminViewParticipantsActivity"
            android:exported="false" />

        <activity
            android:name=".AdminViewUserProfileActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- CHAT -->
        <!-- ===================== -->
        <activity
            android:name=".chat.ChatActivity"
            android:exported="false" />

        <activity
            android:name=".chat.ChatListActivity"
            android:exported="false" />

        <activity
            android:name=".chat.AdminChatListActivity"
            android:exported="false" />

        <!-- ===================== -->
        <!-- NOTIFICATION -->
        <!-- ===================== -->
        <activity
            android:name=".notification.NotificationActivity"
            android:exported="false" />

    </application>

</manifest>
