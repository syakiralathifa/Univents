<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- EVENT TITLE -->
    <TextView
        android:id="@+id/tvEventTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_event_title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- EVENT DATE -->
    <TextView
        android:id="@+id/tvEventDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_event_date"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <!-- PARTICIPANTS COUNT -->
    <TextView
        android:id="@+id/tvParticipantsCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/label_participants"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"/>

    <!-- BUTTONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- EDIT BUTTON -->
        <Button
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="@string/btn_edit"
            android:backgroundTint="#5B72F2"
            android:textColor="#FFFFFF"/>

        <!-- DELETE BUTTON -->
        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="@string/btn_delete"
            android:layout_marginStart="10dp"
            android:backgroundTint="#D9534F"
            android:textColor="#FFFFFF"/>

        <!-- VIEW PARTICIPANTS -->
        <Button
            android:id="@+id/btnViewParticipants"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="48dp"
            android:text="@string/btn_view_participants"
            android:layout_marginStart="10dp"
            android:backgroundTint="#5B72F2"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
