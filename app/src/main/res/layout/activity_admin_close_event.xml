<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F4F6FA">

    <TextView
        android:id="@+id/txtCloseEventTitle"
        android:text="Close Event"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"
        android:textColor="#2E3A59"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtCloseEventDesc"
        android:text="If you close this event, all ACCEPTED participants will receive experience on their profile."
        android:textSize="16sp"
        android:textColor="#555"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnCloseEvent"
        android:text="Close Event"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:backgroundTint="#FF6B6B"
        android:textColor="#FFF"/>

</LinearLayout>
