<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AdminViewParticipantsActivity">

    <!-- RecyclerView untuk menampilkan daftar partisipan -->
    <!-- PASTIKAN ID-NYA ADALAH 'recyclerParticipants' -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerParticipants"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:listitem="@layout/item_participant" />

    <!-- ProgressBar yang akan tampil saat loading -->
    <!-- PASTIKAN ID-NYA ADALAH 'progressBar' -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

    <!-- TextView yang akan tampil jika tidak ada partisipan -->
    <!-- PASTIKAN ID-NYA ADALAH 'tvNoParticipants' -->
    <TextView
        android:id="@+id/tvNoParticipants"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Belum ada partisipan yang terdaftar."
        android:textSize="16sp"
        android:visibility="gone" />

</RelativeLayout>
